{
  "name": "@haloforge/plugin-sdk",
  "version": "0.1.0",
  "description": "HaloForge Plugin SDK — build frontend components for HaloForge plugins",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch"
  },
  "peerDependencies": {
    "@tauri-apps/api": "^2",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "lucide-react": "*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "~5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AuroraPixel/haloforge-plugin-api",
    "directory": "js"
  },
  "keywords": ["haloforge", "plugin", "sdk", "tauri", "gamedev"],
  "license": "MIT"
}
